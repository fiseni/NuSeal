<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <Target Name="NuSealCheckDirectReference"
          BeforeTargets="BeforeCompile">
    <PropertyGroup>
      <IsNuSealPackageReferenced>@(PackageReference->WithMetadataValue('Identity', 'NuSeal')->'%(Identity)'->Count())</IsNuSealPackageReferenced>
      <IsNuSealPackageReferenced>1</IsNuSealPackageReferenced>
    </PropertyGroup>
  </Target>

  <Target Name="NuSealInjectProtectedAttribute"
          BeforeTargets="BeforeCompile"
          DependsOnTargets="NuSealCheckDirectReference"
          Condition="$(IsNuSealPackageReferenced) != 0">
    <ItemGroup>
      <AssemblyAttribute Include="NuSeal.NuSealProtectedAttribute" />
    </ItemGroup>
  </Target>

  <Target Name="NuSealInjectValidationBehaviorAttribute"
          BeforeTargets="BeforeCompile"
          DependsOnTargets="NuSealCheckDirectReference"
          Condition="$(IsNuSealPackageReferenced) != 0 And '$(NuSealValidationBehavior)' != ''">
    <ItemGroup>
      <AssemblyAttribute Include="NuSeal.NuSealValidationBehaviorAttribute">
        <_Parameter1>$(NuSealValidationBehavior)</_Parameter1>
      </AssemblyAttribute>
    </ItemGroup>
  </Target>

  <Target Name="NuSealLicenseValidation"
          AfterTargets="AfterBuild"
          DependsOnTargets="NuSealCheckDirectReference"
          Condition="'$(NuSealValidateAllTypes)' == 'enable' Or '$(OutputType)' == 'Exe' Or '$(OutputType)' == 'WinExe' Or '$(MSBuildProjectSdk)' == 'Microsoft.NET.Sdk.Web'">
    <Message Importance="High" Text="NuSealLicenseValidation: " />

    <NuSeal.LicenseValidationTask MainAssemblyPath="$(TargetPath)" />
  </Target>

  <Target Name="NuSealCopyAssets"
          BeforeTargets="Build"
          DependsOnTargets="NuSealCheckDirectReference"
          Condition="$(IsNuSealPackageReferenced) != 0 And '$(NuSealTransitiveBehavior)' == 'disable'">
    
    <Message Importance="High" Text="IsNuSealPackageReferenced: $(IsNuSealPackageReferenced)" />
    <PropertyGroup>
      <NuSealProps>$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)', 'NuSeal.props'))</NuSealProps>
      <NuSealTargets>$([MSBuild]::NormalizePath('$(MSBuildThisFileDirectory)', 'NuSeal.targets'))</NuSealTargets>
    </PropertyGroup>
    
    <Copy SourceFiles="$(NuSealProps)" DestinationFolder="$(OutputPath)" ContinueOnError="false" />
    <Copy SourceFiles="$(NuSealTargets)" DestinationFolder="$(OutputPath)" ContinueOnError="false" />

    <WriteLinesToFile
        File="$(OutputPath)\NuSeal.props"
        Lines="$([System.IO.File]::ReadAllText('$(OutputPath)\NuSeal.props').Replace('&lt;NuSealValidateAllTypes&gt;disable&lt;/NuSealValidateAllTypes&gt;', '&lt;NuSealValidateAllTypes&gt;enable&lt;/NuSealValidateAllTypes&gt;'))"
        Overwrite="true" />

    <ItemGroup Label="Packaging build assets">
      <None Include="$(OutputPath)\NuSeal.props" Pack="true" PackagePath="build\$(PackageId).props" Visible="false"/>
      <None Include="$(OutputPath)\NuSeal.targets" Pack="true" PackagePath="build\$(PackageId).targets" Visible="false"/>
    </ItemGroup>
  </Target>

</Project>
